# Pi/server target
SERVER_USER=trungnt
SERVER_HOST=100.106.17.78
SERVER_PORT=
REMOTE_DIR=/tmp/mux_experiment

# Python binaries. The runner can create venvs automatically when QUIC needs aioquic.
LOCAL_BOOTSTRAP_PYTHON=python3
REMOTE_BOOTSTRAP_PYTHON=python3
AUTO_INSTALL_AIOQUIC=1
LOCAL_PYTHON_BIN=.venv/bin/python
REMOTE_PYTHON_BIN=/tmp/mux_experiment/.venv/bin/python

# Experiment
PROTOCOLS=quic,tcp,udp
PROFILES=c0_only,c0_bg2,c0_bg4,c0_bg4_heavy
RUNS=100
MUX_PORT=44333
INTERVAL=0.20
TIMEOUT=2.00
WARMUP_SECONDS=0.50
RESULT_DIR=results_mux
LOG_DIR=logs_mux
LIVE_PROGRESS=1

# QUIC capture/decryption
QUIC_KEYLOG=quic_keylog.log

# Optional packet capture. Requires tcpdump/sudo on the client machine.
CAPTURE=0
CAPTURE_IFACE=any
