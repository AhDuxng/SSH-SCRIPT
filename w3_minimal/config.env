# Pi1 = client/AI-agent driver. Pi2 = server/target.
SERVER_USER=trungnt
SERVER_HOST=100.106.17.78
# Leave empty for the Raspberry Pi default SSH port.
SERVER_PORT=

# Remote workload script path on Pi2
REMOTE_WORKLOAD=/tmp/w3_remote_workloads.sh

# Experiment control
PROTOCOLS=ssh,ssh3,mosh
TARGETS=shell,vim,nano
RUNS=100
TOKEN_INTERVAL=0.20
TOKEN_TIMEOUT=2.00
STALL_THRESHOLD_MS=1000
RESULT_DIR=results
LOG_DIR=logs
EDITOR_START_DELAY=0.80

# Display while running on Pi1
LIVE_PROGRESS=1
SHOW_TERMINAL_OUTPUT=0

# Local binaries on Pi1
SSH_BIN=ssh
SSH3_BIN=ssh3
MOSH_BIN=mosh
VIM_BIN=vim
NANO_BIN=nano

# Remote editor commands. Payload tokens are still alphanumeric only.
VIM_COMMAND="{vim} -Nu NONE -n -i NONE {file}"
NANO_COMMAND="{nano} -t {file}"

# SSH3 CLI syntax differs across builds. Adjust these two templates if needed.
# {user}, {host}, {port}, {cmd} are filled by run_w3.py.
SSH3_INTERACTIVE_TEMPLATE="ssh3 {user}@{host}"
SSH3_COMMAND_TEMPLATE="ssh3 {user}@{host} -- {cmd}"
