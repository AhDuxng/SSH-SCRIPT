# Pi1 = client/AI-agent driver. Pi2 = server/target.
SERVER_USER=trungnt
SERVER_HOST=100.106.17.78
# Leave empty for the Raspberry Pi default SSH port.
SERVER_PORT=

# Remote workload script path on Pi2
REMOTE_WORKLOAD=/tmp/w3_remote_workloads.sh

# Experiment control
PROTOCOLS=ssh,ssh3,mosh
TARGETS=shell,vim,nano
RUNS=100
TOKEN_INTERVAL=0.20
TOKEN_TIMEOUT=2.00
STALL_THRESHOLD_MS=1000
RESULT_DIR=results
LOG_DIR=logs
EDITOR_START_DELAY=0.80
PROBE_SEQUENCE=ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789
PROBE_SEARCH_WINDOW=0

# Display while running on Pi1
LIVE_PROGRESS=1
SHOW_TERMINAL_OUTPUT=0

# Local binaries on Pi1
PYTHON_BIN=python
SSH_BIN=ssh
SSH3_BIN=ssh3
MOSH_BIN=mosh
MOSH_PREDICT=always
MOSH_EXTRA_ARGS=
VIM_BIN=vim
NANO_BIN=nano

# Remote editor commands. Payload tokens are still alphanumeric only.
VIM_COMMAND="{vim} -Nu NONE -n -i NONE {file}"
NANO_COMMAND="{nano} -t {file}"

# SSH3 audit/debug. Verbose logs are captured in logs/, keylog files can be used with packet captures.
SSH3_INSECURE=1
SSH3_PRIVKEY=~/.ssh/id_rsa
SSH3_PATH=/ssh3-term
SSH3_VERBOSE=1
SSH3_CAPTURE_DEBUG=1
SSH3_EXTRA_ARGS=
SSH3_KEYLOG_TEMPLATE=logs/ssh3_keylog_{target}_{profile}_{role}_{pid}_{ts}.log
SSH3_STREAM_SCAN_BYTES=200000

# SSH3 CLI syntax differs across builds. Adjust these two templates if needed.
# {user}, {host}, {port}, {cmd} are filled by run_w3.py.
SSH3_INTERACTIVE_TEMPLATE="ssh3 {ssh3_extra_args} {user}@{host}{ssh3_path}"
SSH3_COMMAND_TEMPLATE="ssh3 {ssh3_extra_args} {user}@{host}{ssh3_path} {cmd}"
